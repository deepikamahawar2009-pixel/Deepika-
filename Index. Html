}
.price {
    font-size: 20px;
    color: green;
    font-weight: bold;
}
button {
    background: #4e73df;
    color: white;
    border: none;
    padding: 10px 20px;
    border-radius: 8px;
    cursor: pointer;
    margin-top: 10px;
}
button:hover {
    background: #224abe;
}
.payment {
    background: #e8efff;
    padding: 20px;
    margin-top: 30px;
    border-radius: 15px;
